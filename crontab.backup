# ============================================================
# Crontab - PocketBase RT Management Backup
# ============================================================
# Backup otomatis setiap hari jam 00:00 (tengah malam)
# Notifikasi dikirim ke https://ntfy.sh/p2s
#
# Install crontab:
#   crontab /home/nurahmat/pocketbase/crontab.backup
#
# Daftar cron yang aktif:
#   crontab -l
# ============================================================

# ─── Jam 00:00 - Backup koleksi via API ──────────────────────
0 0 * * * cd /home/nurahmat/pocketbase && ./backup_collections.sh >> /var/log/pocketbase-collections-backup.log 2>&1

# ─── Jam 00:05 - Backup database volume ──────────────────────
5 0 * * * cd /home/nurahmat/pocketbase && ./db.sh backup >> /var/log/pocketbase-db-backup.log 2>&1

# ─── Hapus backup koleksi > 30 hari ──────────────────────────
10 0 * * * find /var/data/pocketbase/backup/ -maxdepth 1 -type d -name "????-??-??" -mtime +30 -exec rm -rf {} + 2>/dev/null

# ─── Hapus backup db > 60 hari ───────────────────────────────
15 0 * * * find /var/data/pocketbase/backup/ -maxdepth 1 -type f -name "file-*.tar.gz" -mtime +60 -delete 2>/dev/null